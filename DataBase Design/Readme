Data Types
TypeUse ForExampleINTWhole numbers, IDs, counts1, 25, 1000DECIMAL(p,s)Prices, salaries with decimals75000.00VARCHAR(n)Names, emails, variable text'Rahul Sharma'CHAR(n)Fixed codes like country codes'IN', 'US'DATEDates only'2024-01-15'DATETIMEDate + time together'2024-01-15 10:30:00'BOOLEANTrue/False flagsTRUE, FALSE

Primary Key vs Foreign Key
Primary KeyForeign KeyPurposeUniquely identifies each rowLinks to another table's PKDuplicates❌ Not allowed✅ AllowedNULL❌ Not allowed❌ Not allowedPer tableOnly one PKCan have many FKsKeywordPRIMARY KEYFOREIGN KEY ... REFERENCES

Constraints
ConstraintWhat It DoesExampleNOT NULLColumn must always have a valuefirst_name VARCHAR(50) NOT NULLUNIQUEAll values must be differentemail VARCHAR(100) UNIQUEDEFAULTAuto-fills value if none givenstatus VARCHAR(20) DEFAULT 'Pending'CHECKOnly allows values meeting conditionprice DECIMAL CHECK (price > 0)PRIMARY KEYNOT NULL + UNIQUE combinedPRIMARY KEY (customer_id)FOREIGN KEYLinks to PK of another tableFOREIGN KEY (customer_id) REFERENCES customers(customer_id)

💻 Full Schema — Quick Copy
sqlCREATE DATABASE store_db;
USE store_db;

CREATE TABLE customers (
    customer_id  INT           AUTO_INCREMENT,
    first_name   VARCHAR(50)   NOT NULL,
    last_name    VARCHAR(50)   NOT NULL,
    email        VARCHAR(100)  NOT NULL UNIQUE,
    phone        VARCHAR(20),
    city         VARCHAR(50),
    created_at   DATE          DEFAULT (CURRENT_DATE),
    PRIMARY KEY  (customer_id)
);

CREATE TABLE products (
    product_id   INT            AUTO_INCREMENT,
    product_name VARCHAR(100)   NOT NULL,
    category     VARCHAR(50),
    price        DECIMAL(10, 2) NOT NULL CHECK (price > 0),
    stock        INT            DEFAULT 0,
    PRIMARY KEY  (product_id)
);

CREATE TABLE orders (
    order_id     INT          AUTO_INCREMENT,
    customer_id  INT          NOT NULL,
    product_id   INT          NOT NULL,
    quantity     INT          NOT NULL CHECK (quantity > 0),
    order_date   DATE         DEFAULT (CURRENT_DATE),
    status       VARCHAR(20)  DEFAULT 'Pending',
    PRIMARY KEY  (order_id),
    FOREIGN KEY  (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY  (product_id)  REFERENCES products(product_id)
);

✅ Verify Your Tables
sql-- See all tables created
SHOW TABLES;

-- Check structure of each table
DESCRIBE customers;
DESCRIBE products;
DESCRIBE orders;

⚠️ Common Mistakes to Avoid
MistakeWhy It's a ProblemFixStoring price as VARCHARCan't do math on itUse DECIMAL(10,2)No NOT NULL on important columnsAllows empty data inAdd NOT NULLForgetting PRIMARY KEYNo way to uniquely identify rowsAlways add PKInserting orders before customersFK will throw an errorInsert in correct orderNo CHECK on priceAllows negative pricesAdd CHECK (price > 0)
